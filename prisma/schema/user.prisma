model User {
  id           String     @id @default(uuid())
  name         String
  email        String     @unique
  password     String
  phone        String?
  role         Role       @default(CUSTOMER)
  status       UserStatus @default(ACTIVE)
  profilePhoto String?
  address      String?
  city         String?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  @@map("users")
}
