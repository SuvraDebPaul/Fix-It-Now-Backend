model Booking {
  id           String        @id @default(uuid())
  customerId   String        @unique
  technicianId String        @unique
  serviceId    String        @unique
  scheduleTime DateTime
  address      String
  status       BookingStatus @default(REQUESTED)
  totalAmount  Decimal
  cancelReason String?
  completedAt  DateTime
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  customerProfiles   CustomerProfile   @relation(fields: [customerId], references: [id], onDelete: Cascade)
  technicianProfiles TechnicianProfile @relation(fields: [technicianId], references: [id], onDelete: Cascade)
  services           Service           @relation(fields: [serviceId], references: [id], onDelete: Cascade)

  review Review[]

  @@map("bookings")
}
